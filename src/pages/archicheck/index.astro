---
import { getAugmentedProjects } from '../../utils/contentAugmentation';
import { useTranslations } from '../../i18n/utils';

import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Services from '../../components/Services.astro';
import Service from '../../components/Service.astro';
import ImgSection from '../../components/ImgSection.astro';
import SlidesPoi from '../../components/SlidesPoi.astro';
import SlidePoi from '../../components/SlidePoi.astro';
import SlidesSteps from '../../components/SlidesSteps.astro';
import SectionExpandable from '../../components/SectionExpandable.astro';
import SlidesProjects from '../../components/SlidesProjects.astro';
import Gallery from '../../components/Gallery.astro';
import SubTitle from '../../components/SubTitle.astro';
import { processGalleryImages } from '../../utils/imageUtils';

const lang = Astro.currentLocale as keyof typeof import('../../i18n/utils').languages;
const t = useTranslations(lang);

const selectedProjectDirs = [
	"dom-s-pavlacou",
	"usadlost-na-cervenej-hore",
	"dom-s-mestskym-nadychom",
	"dom-s-bazenom-v-rusovciach",
	"dom-za-mestom",
	"dom-s-cortenom-pri-piestanoch",
	"dom-so-saunou-na-povazi",
	



];

const allProjects = await getAugmentedProjects(lang);
const projectsByDir = new Map(allProjects.map(p => [p.data.dir, p]));
const selectedProjects = selectedProjectDirs.map(dir => projectsByDir.get(dir)).filter(Boolean);

const galleryImageLoaders = import.meta.glob('./gallery/*.{jpg,jpeg,png,webp,gif,heic}');
const galleryImages = await processGalleryImages(galleryImageLoaders as any, 'Habitat konfigurátor');
---

<Layout 
	bodyClass="home"
>
	<Hero 
		className="hero--home"
		imgSrc="/assets/img/A_4_KOMB_D_OM.jpg"
		imgAlt="Vizualizácia domu"
	>
		Archicheck
	</Hero>
	<a id="main"></a>
	
	
	<SubTitle>
		Vyhnite sa chybám pri plánovaní projektu a začnite s nami pripravení! 
	</SubTitle>
	
	<ImgSection 
		id='preco-habitat'
		imgSrc="/assets/img/E3_OM_DREVO_TRAVAOFF.jpg"
		imgAlt="Vizualizácia domu"
	>
		<Fragment slot="content">
			<h2>Prečo? </h2>
			<p>Zvažujete kúpu pozemku, stavbu pasívneho domu alebo rekonštrukciu? Potrebujete poradiť ako postupovať pri návrhu a povolovaní stavby? Neviete sa rozhodnúť, či je pre vás vhodný Habitat Konfigurátor alebo Domov na mieru? Chcete prebrať vaše predstavy a nápady a získať názor profesionálov z praxe?</p>
			<p>Všetky tieto a mnohé ďalšie otázky vám osobne zodpovieme na <strong>Archichecku</strong> - osobnej konzultácií na vašom pozemku alebo stavbe. Ako bonus si overíte chémiu medzi klientom a architektom, čo je dôležitý predpoklad úspešného projektu.</p>
			
		</Fragment>
	</ImgSection>

	<Gallery images={galleryImages} lang={lang} title="Galéria"/>
	
	<SlidesSteps
		title="Ako to prebieha?"
		steps={[
			{
				title: "Vyplníte dotazník",
				text: "Bude nás zaujímať o aký pozemok alebo stavbu ide, ako je lokalita zaregulovaná, aké sú vaše predstavy a očakávania.",
			},
			{
				title: "Pripravíme analýzy a odpočúčania",
				text: "Rozoberieme si špecifiká vášho pozemku, jeho potenciály a riziká, ktoré môžu ovplyvniť rozpočet stavby. Zhodnotíme jeho preslnenie a orientáciu na svetové strany. Odhadneme výšku investície a predostrieme, ako by sme váš projekt riešili u nás v ateliéri.",
			},
			{
				title: "Stretneme sa na lokalite",
				text: "Priamo na mieste s vami prejdeme všetky otázky, naše odporúčania a rady z praxe.",
			},
			{
				title: "Odovzdáme vám Archicheck",
				text: "Po stretnutí vypracujeme elaborát so zhrnutím základných faktov a odporúčaní, ktorý viete použiť pri ďalšom plánovaní.",
			},
			{
				title: "A čo ďalej?",
				text: "Radi vám pripravíme ďalší plán pre vás projekt a na základe odporúčaní Archichecku vypracujeme cenové ponuky pre architektonické služby a realizáciu.",
			}
		]}
	/>

	
	
	
	<SlidesProjects
		title="Naše projekty"
		projects={selectedProjects}
	/>

	

</Layout>
