---
import { getAugmentedProjects } from '../../utils/contentAugmentation';
import { useTranslations } from '../../i18n/utils';

import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Services from '../../components/Services.astro';
import Service from '../../components/Service.astro';
import ImgSection from '../../components/ImgSection.astro';
import SlidesPoi from '../../components/SlidesPoi.astro';
import SlidePoi from '../../components/SlidePoi.astro';
import SlidesSteps from '../../components/SlidesSteps.astro';
import SectionExpandable from '../../components/SectionExpandable.astro';
import SlidesProjects from '../../components/SlidesProjects.astro';
import Gallery from '../../components/Gallery.astro';
import SubTitle from '../../components/SubTitle.astro';
import { processGalleryImages } from '../../utils/imageUtils';

const lang = Astro.currentLocale as keyof typeof import('../../i18n/utils').languages;
const t = useTranslations(lang);

const selectedProjectDirs = [
	"dom-s-dlhou-pergolou",
	"dom-l-s-tehlovym-obkladom",
	"dom-s-nadcasovym-dizajnom",
	"dom-s-utulnou-terasou",
	"dom-v-zahrade",
	"dom-s-drevenym-obkladom",
	"dom-s-kontrastom",
	"dom-s-mestskym-nadychom",
	"dom-s-otvorenym-krovom",
	"dom-s-pavlacou",
	"dom-so-sikmymi-stlpmi",
	"dom-pre-velku-rodinu",
	"dom-za-mestom",
	



];

const allProjects = await getAugmentedProjects(lang);
const projectsByDir = new Map(allProjects.map(p => [p.data.dir, p]));
const selectedProjects = selectedProjectDirs.map(dir => projectsByDir.get(dir)).filter(Boolean);

const galleryImageLoaders = import.meta.glob('./gallery/*.{jpg,jpeg,png,webp,gif,heic}');
const galleryImages = await processGalleryImages(galleryImageLoaders as any, 'Habitat konfigurátor');
---

<Layout 
	bodyClass="home"
>
	<Hero 
		className="hero--home"
		imgSrc="/assets/img/A_4_KOMB_D_OM.jpg"
		imgAlt="Vizualizácia domu"
	>
		Habitat <br>konfigurátor
	</Hero>
	<a id="main"></a>
	
	
	<SubTitle>
		Sestavíme vám domov z našich osvědčených řešení a&nbsp;ušetříte čas i peníze.
	</SubTitle>
	
	<ImgSection 
		id='preco-habitat'
		imgSrc="/assets/img/E3_OM_DREVO_TRAVAOFF.jpg"
		imgAlt="Vizualizácia domu"
	>
		<Fragment slot="content">
			<h2>Proč? </h2>
			<p><strong>Habitat Konfigurátor</strong> je naší odpovědí na neuspokojivou nabídku katalogových domů na trhu. Ty nezohledňují specifika pozemku a klienta, jsou málo dispozičně flexibilní a architektonicky těžko modifikovatelné. V době, kdy stále více záleží na kvalitě vnitřního prostředí a energetice se katalogové domy nekoncepčně umísťují na parcely, bez zohlednění orientace na světové strany, energetické optimalizace či účinného stínění.</p>
			<p>Sesbírali jsme nejčastější dispoziční a konstrukční zadání, přidali naše know-how a vytvořili tak inovativní systém tvorby rodinných domů. Máme připraveny stovky kombinací a ověřených řešení, které následně přizpůsobíme přesnými výpočty pro váš konkrétní pozemek. Takto umíme ušetřit čas i peníze ve fázi architektonického návrhu s jistotou, že váš dům bude splňovat nejvyšší nároky na bydlení a energetickou efektivnost stavby.</p>
			
		</Fragment>
	</ImgSection>

	<Gallery images={galleryImages} lang={lang} title="Galerie"/>
	
	<SlidesSteps
		title="Jak to probíhá?"
		steps={[
			{
				title: "Pošlete nám svou představu",
				text: "Na základě podkladů, pozemku a územního plánu zdarma posoudíme, zda je Habitat Konfigurátor vhodnou volbou pro vaši stavbu, a zašleme vám ukázky možných konfigurací.",
			},
			{
				title: "Společně nakonfigurujeme půdorys",
				text: "Během tříhodinového kreativního sezení s naším architektem si sestavíte svůj dům z optimalizovaných a stavebně promyšlených modulů. Vyberete si vhodný typ dispozice, počet a velikost pokojů, koupelen či šaten.",
			},
			{
				title: "Vyberete si vzhled domu",
				text: "Pro každý půdorys máme připravené varianty od nejjednodušší architektury až po nejvyšší standard, od tradičních domů až po moderní vily. Určitě si vyberete.",
			},
			{
				title: "Dům individuálně přizpůsobíme vašemu pozemku",
				text: "Ověříme orientaci a velikost oken, rozměry stínících prvků a energetický standard domu. Zapracujeme nezbytná opatření, aby váš dům fungoval pasivně – v zimě s minimálním vytápěním a v létě bez klimatizace.",
			},
			{
				title: "Vyexportujeme projektovou dokumentaci",
				text: "Během krátké doby získáte vše, co potřebujete k získání povolení od úřadů a k úspěšné výstavbě. V kvalitě individuálního projektu a za bezkonkurenční cenu.",
			}
		]}
	/>

	
	
	
	<SlidesProjects
		title="Ukázky konfigurací"
		projects={selectedProjects}
	/>

	

</Layout>
